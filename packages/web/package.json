{
  "name": "@takehomeviz/web",
  "version": "0.1.0",
  "private": true,
  "description": "Vue SPA for TakeHomeViz",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "fmt": "prettier --check \"src/**/*.{ts,vue}\"",
    "fmt:fix": "prettier --write \"src/**/*.{ts,vue}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "3",
    "@takehomeviz/engine": "workspace:*",
    "lz-string": "^1.5.0",
    "pinia": "^3.0.4",
    "uplot": "^1.6.32",
    "vue": "^3.5.32",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
